# FutuOpenD & API verification
FUTU_LOGIN_ACCOUNT=your_account_id
FUTU_LOGIN_PWD_MD5=your_password_md5
FUTU_OPEND_HOST=localhost
FUTU_OPEND_PORT=11111

# LLM Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/futu_agent?sslmode=disable

# Server
SERVER_PORT=8080

# Proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=

# Trading
TRADING_ENABLED=false
